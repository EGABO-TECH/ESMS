title Enterprise School Management System Architecture

Users [icon: users] {
  Admin [icon: user-check]
  Teacher [icon: user]
  Parent [icon: users]
  Student [icon: book-open]
  Accountant[icon: money]
  HR[icon: person]
}

Web Browser [icon: monitor]

CDN Edge Network [icon: globe, label: "CDN / Edge (Vercel)"]

Frontend [icon: nextjs, color: black] {
  Next.js App [icon: nextjs, label: "Next.js Frontend"]
  SIS Views [icon: user-check] {
    Student Profiles View [icon:users]
    Admissions View [icon:user-plus]
    SIS Documents View [icon:file, label:"Documents View"]
    Promotion View [icon:trending-up]
    Alumni View [icon:award]
  }
  Academics Views [icon: book] {
    Classes View [icon:grid]
    Subjects View [icon:bookmark]
    Timetable View [icon:calendar]
    Curriculum View [icon:list]
  }
  Attendance Views [icon: check-square] {
    Attendance Dashboard View [icon:activity]
    Biometric View [icon:cpu]
    Attendance Alerts View [icon:bell, label:"Alerts View"]
  }
  Exams Views [icon: file-text] {
    Exams Dashboard View [icon:clipboard]
    Assessments View [icon:edit-3]
    Results View [icon:award]
    Exam Analytics View [icon:trending-up]
  }
  Finance Views [icon: dollar-sign] {
    Finance Dashboard View [icon:pie-chart]
    Payments View [icon:credit-card]
    Receipts View [icon:file-text]
    Scholarships View [icon:gift]
    Fee Setup View [icon:settings]
  }
  Staff Views [icon: briefcase] {
    Teachers View [icon:user]
    Staff HR View [icon:users, label:"HR View"]
    Leave View [icon:calendar]
    Payroll View [icon:dollar-sign]
  }
  Communication Views [icon: mail] {
    Messages View [icon:message-square]
    Announcements View [icon:megaphone]
    Broadcast View [icon:radio]
  }
  Other Views [icon: grid] {
    Main Dashboard View [icon:home, label:"Dashboard View"]
    Calendar View [icon:calendar]
    Library View [icon:book-open]
    Hostel View [icon:home]
    Transport View [icon:truck]
    Inventory View [icon:package]
    Procurement View [icon:shopping-cart]
    Frontend Analytics View [icon:bar-chart-2, label:"Analytics View"]
    Parent Portal View [icon:users]
    Student Management View [icon:database]
  }
}

Edge Middleware [icon: shield, color: orange] {
  Auth Validation [icon: lock]
  Session Handler [icon: key]
  Rate Limiter [icon: clock]
  Subdomain Resolver [icon: globe]
}

Better Auth [icon: lock, color: purple] {
  MFA [icon: smartphone]
  Session Management [icon: database]
  Role Management [icon: users]
  Device Fingerprint [icon: cpu]
}

Application Backend [icon: server, color: blue] {
  SIS [icon: user-check] {
    Student Profiles [icon:users]
    Admissions [icon:user-plus]
    SIS Documents [icon:file, label:"Documents"]
    Promotion [icon:trending-up]
    Alumni [icon:award]
  }
  Academics [icon: book] {
    Classes [icon:grid]
    Subjects [icon:bookmark]
    Timetable [icon:calendar]
    Curriculum [icon:list]
  }
  Attendance [icon: check-square] {
    Attendance Dashboard [icon:activity]
    Biometric Integration [icon:cpu]
    Attendance Alerts [icon:bell, label:"Alerts"]
  }
  Examinations [icon: file-text] {
    Exams Dashboard [icon:clipboard]
    Assessments [icon:edit-3]
    Results [icon:award]
    Exam Analytics [icon:trending-up]
  }
  Finance [icon: dollar-sign] {
    Finance Dashboard [icon:pie-chart]
    Payments [icon:credit-card]
    Receipts [icon:file-text]
    Scholarships [icon:gift]
    Fee Setup [icon:settings]
  }
  Staff Management [icon: briefcase] {
    Teachers [icon:user]
    Staff HR [icon:users, label:"HR"]
    Leave [icon:calendar]
    Payroll [icon:dollar-sign]
  }
  Communication [icon: mail] {
    Messages [icon:message-square]
    Announcements [icon:megaphone]
    Broadcast [icon:radio]
  }
  Other Modules [icon: grid] {
    Main Dashboard [icon:home, label:"Dashboard"]
    Calendar [icon:calendar]
    Library [icon:book-open]
    Hostel [icon:home]
    Transport [icon:truck]
    Inventory [icon:package]
    Procurement [icon:shopping-cart]
    School Analytics [icon:bar-chart-2, label:"Analytics"]
    Parent Portal [icon:users]
    Student Management [icon:database]
  }
}

Dynamic DB Resolver [icon: database, color: green]

Cache Layer [icon: database, label: "Redis / Edge Cache", color: teal]

Job Queue [icon: cpu, label: "Background Workers"]

Central Control Platform [icon: settings, color: red] {
  School Management [icon: home]
  Subscriptions [icon: credit-card]
  Billing [icon: dollar-sign]
  Domain Management [icon: globe]
  Provisioning [icon: server]
  Monitoring [icon: activity]
}

Master Database [icon: database, label: "Master Neon PostgreSQL"]

School Databases [icon: database, color: green] {
  School A DB [icon: database, label: "School A (Isolated)"]
  School B DB [icon: database, label: "School B (Isolated)"]
  School C DB [icon: database, label: "School C (Isolated)"]
}

External Services [icon: cloud, color: gray] {
  Payment Gateway [icon: credit-card, label: "Paystack/Flutterwave"]
  Email SMS [icon: mail, label: "Email & SMS"]
  File Storage [icon: hard-drive]
  Prometheus [icon: activity]
  Grafana [icon: bar-chart-2]
}

// User flow
Users > Web Browser
Web Browser > CDN Edge Network
CDN Edge Network > Frontend

// Frontend to middleware
Frontend > Edge Middleware

// Auth connections
Edge Middleware <> Better Auth
Application Backend <> Better Auth
Central Control Platform <> Better Auth

// Middleware to backend
Edge Middleware > Application Backend

// Backend caching
Application Backend <> Cache Layer

// Background processing
Application Backend > Job Queue
Job Queue > Email SMS

// Backend to database resolver
Application Backend > Dynamic DB Resolver

// Database resolver connections
Dynamic DB Resolver > Master Database: fetch DB URL
Dynamic DB Resolver > School Databases: connect

// Central control connections
Central Control Platform <> Master Database

// External service connections
Application Backend > Payment Gateway
Application Backend > File Storage

// Monitoring
Application Backend > Prometheus
Central Control Platform > Prometheus
Prometheus > Grafana
